<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- العنوان -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🕌 متتبع الصلاة"
                android:textColor="@color/colorAccent"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <!-- التاريخ -->
            <TextView
                android:id="@+id/text_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/title_color"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- بروجريس -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/panel_background_color"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/text_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 / 5 صلوات"
                    android:textColor="@color/colorAccent"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="12dp" />

                <ProgressBar
                    android:id="@+id/progress_prayers"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:max="5"
                    android:progress="0"
                    android:progressTint="#D4AF37"
                    android:progressBackgroundTint="#1E2E50" />

                <TextView
                    android:id="@+id/text_motivation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="اللهم أعنّا على ذكرك وشكرك وحسن عبادتك"
                    android:textColor="@color/sura_details_color"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="12dp" />

            </LinearLayout>

            <!-- الفجر -->
            <LinearLayout
                android:id="@+id/card_fajr"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:orientation="horizontal"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="10dp"
                android:padding="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌙 الفجر"
                    android:textColor="@color/title_color"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="end" />

                <CheckBox
                    android:id="@+id/check_fajr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:buttonTint="#D4AF37"
                    android:scaleX="1.4"
                    android:scaleY="1.4" />

            </LinearLayout>

            <!-- الظهر -->
            <LinearLayout
                android:id="@+id/card_dhuhr"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:orientation="horizontal"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="10dp"
                android:padding="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="☀️ الظهر"
                    android:textColor="@color/title_color"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="end" />

                <CheckBox
                    android:id="@+id/check_dhuhr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:buttonTint="#D4AF37"
                    android:scaleX="1.4"
                    android:scaleY="1.4" />

            </LinearLayout>

            <!-- العصر -->
            <LinearLayout
                android:id="@+id/card_asr"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:orientation="horizontal"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="10dp"
                android:padding="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌤️ العصر"
                    android:textColor="@color/title_color"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="end" />

                <CheckBox
                    android:id="@+id/check_asr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:buttonTint="#D4AF37"
                    android:scaleX="1.4"
                    android:scaleY="1.4" />

            </LinearLayout>

            <!-- المغرب -->
            <LinearLayout
                android:id="@+id/card_maghrib"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:orientation="horizontal"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="10dp"
                android:padding="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌅 المغرب"
                    android:textColor="@color/title_color"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="end" />

                <CheckBox
                    android:id="@+id/check_maghrib"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:buttonTint="#D4AF37"
                    android:scaleX="1.4"
                    android:scaleY="1.4" />

            </LinearLayout>

            <!-- العشاء -->
            <LinearLayout
                android:id="@+id/card_isha"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:orientation="horizontal"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="10dp"
                android:padding="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌙 العشاء"
                    android:textColor="@color/title_color"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="end" />

                <CheckBox
                    android:id="@+id/check_isha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:buttonTint="#D4AF37"
                    android:scaleX="1.4"
                    android:scaleY="1.4" />

            </LinearLayout>

            <!-- زر إعادة تعيين -->
            <Button
                android:id="@+id/btn_reset"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/card_bg"
                android:text="🔄 إعادة تعيين اليوم"
                android:textColor="@color/colorAccent"
                android:textSize="15sp" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
