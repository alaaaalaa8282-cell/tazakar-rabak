<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="18dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/widget_clock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="05:27"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center" />

    <TextView
        android:id="@+id/widget_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4 يوليو"
        android:textColor="#D4AF37"
        android:textSize="7sp"
        android:gravity="center"
        android:layout_marginTop="1dp" />

    <TextView
        android:id="@+id/widget_next_prayer_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="العصر 06:29"
        android:textColor="#D4AF37"
        android:textSize="8sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="3dp" />

    <TextView
        android:id="@+id/widget_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="متبقي 00:00"
        android:textColor="#C8B88A"
        android:textSize="6sp"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/widget_weather_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="?"
            android:textSize="7sp"
            android:layout_marginEnd="2dp" />

        <TextView
            android:id="@+id/widget_weather_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#C8B88A"
            android:textSize="6sp" />

    </LinearLayout>

</LinearLayout>
