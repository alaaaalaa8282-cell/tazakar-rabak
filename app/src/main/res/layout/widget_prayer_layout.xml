<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/widget_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/father_bg" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="6dp">

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4"
            android:textColor="#D4AF37"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/widget_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="يوليو"
            android:textColor="#D4AF37"
            android:textSize="9sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/widget_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="05:27"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/widget_next_prayer_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="العصر 06:29"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/widget_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01&quot; 02 h"
            android:textColor="#C8B88A"
            android:textSize="8sp"
            android:gravity="center" />

        <View
            android:layout_width="60dp"
            android:layout_height="1dp"
            android:background="#44D4AF37"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="3dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_weather_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="?"
                android:textSize="10sp"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/widget_weather_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#C8B88A"
                android:textSize="8sp" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
