<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background">

    <ScrollView
        android:id="@+id/container_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- بانر والد مع الإهداء -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp"
                android:background="@color/panel_background_color"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/father_photo"
                    android:scaleType="centerCrop" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="إهداءً إلى روح والدي الحبيب"
                    android:textColor="@color/title_color"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="محمد عبد العظيم طرفايه الطويل"
                    android:textColor="@color/colorAccent"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="رحمه الله وأسكنه فسيح جناته"
                    android:textColor="@color/title_color"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />

            </LinearLayout>

            <!-- كارد التاريخ والرمضان -->
            <LinearLayout
                android:id="@+id/date_ramadan_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp"
                android:background="@color/panel_background_color"
                android:layout_marginBottom="8dp">

                <!-- التاريخ الميلادي -->
                <TextView
                    android:id="@+id/text_gregorian_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/title_color"
                    android:textSize="13sp"
                    android:gravity="center" />

                <!-- التاريخ الهجري -->
                <TextView
                    android:id="@+id/text_hijri_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/colorAccent"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />

                <!-- فاصل -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/translation_divider_color"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- معلومات رمضان -->
                <TextView
                    android:id="@+id/text_ramadan_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/colorAccent"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <!-- عد تنازلي أو أيام متبقية -->
                <TextView
                    android:id="@+id/text_ramadan_countdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/title_color"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Row 1: الأذان + القرآن -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_athan"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/athan"
                    android:text="@string/athan"
                    android:textColor="@color/title_color"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

                <Button
                    android:id="@+id/button_quran"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/quran"
                    android:text="@string/quranic_verses"
                    android:textColor="@color/title_color"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

            </LinearLayout>

            <!-- Row 2: أذكار الصباح + أذكار المساء -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_morning_thikr"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/sun"
                    android:text="@string/morningThikr"
                    android:textColor="@color/title_color"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

                <Button
                    android:id="@+id/button_night_thikr"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/moon"
                    android:text="@string/nightThikr"
                    android:textColor="@color/title_color"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

            </LinearLayout>

            <!-- Row 3: اذكاري + القبلة -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_my_athkar"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/my_athkar"
                    android:text="@string/my_athkar"
                    android:textColor="@color/title_color"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

                <Button
                    android:id="@+id/button_qibla"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/qibla"
                    android:text="@string/qibla"
                    android:textColor="@color/title_color"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

            </LinearLayout>

            <!-- Row 4: حصن المسلم + الإعدادات -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/hisn_almuslim"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/hisn_almuslim"
                    android:text="@string/hisn_almuslim"
                    android:textColor="@color/title_color"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

                <Button
                    android:id="@+id/button_settings"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/settings"
                    android:text="@string/Settings"
                    android:textColor="@color/title_color"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

            </LinearLayout>

            <!-- متتبع الصلاة -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <Button
        android:id="@+id/button_prayer_tracker"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="8dp"
        android:background="@drawable/card_bg"
        android:text="📿 متتبع الصلاة اليومي"
        android:textColor="@color/colorAccent"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="10dp" />

</LinearLayout>
            
            <Button
                android:id="@+id/button_sadaqa"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                android:background="@drawable/card_bg"
                android:drawableTop="@drawable/share_button"
                android:text="@string/sadaqa"
                android:textColor="@color/title_color"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="10dp" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
